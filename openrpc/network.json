    },
    {
      "name": "network.get_netnat_config",
      "summary": "get netnat status",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "enable": {
              "type": "boolean",
              "description": "whether netnat is enabled"
            },
            "actype": {
              "type": "number",
              "description": "acceleration type [0: Software and Hardware Acceleration; 1: Hardware Acceleration; 2: Software Acceleration]",
              "oneOf": [
                {
                  "const": 0,
                  "title": "Software and Hardware Acceleration"
                },
                {
                  "const": 1,
                  "title": "Hardware Acceleration"
                },
                {
                  "const": 2,
                  "title": "Software Acceleration"
                }
              ]
            },
            "list": {
              "type": "array",
              "description": "acceleration type supported [0: Software and Hardware Acceleration; 1: Hardware Acceleration; 2: Software Acceleration]"
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_netnat_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "network",
                  "get_netnat_config",
                  {}
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "enable": true
            }
          }
        }
      ]
    },
    {
      "name": "network.set_netnat_config",
      "summary": "enable/disable netnat",
      "params": [
        {
          "name": "enable",
          "schema": {
            "type": "boolean",
            "description": "whether to enable netnat"
          },
          "required": true
        },
        {
          "name": "actype",
          "schema": {
            "type": "number",
            "description": "acceleration type [0: Software and Hardware Acceleration; 1: Hardware Acceleration; 2: Software Acceleration]",
            "oneOf": [
              {
                "const": 0,
                "title": "Software and Hardware Acceleration"
              },
              {
                "const": 1,
                "title": "Hardware Acceleration"
              },
              {
                "const": 2,
                "title": "Software Acceleration"
              }
            ]
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "null",
            "object"
          ]
        }
      },
      "examples": [
        {
          "name": "set_netnat_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "network",
                  "set_netnat_config",
                  {
                    "enable": true
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
    }
  ]
}