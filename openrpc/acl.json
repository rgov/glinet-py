          "name": "add_acl_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "acl",
                  "add_acl",
                  {
                    "group": "test",
                    "scope": "rpc",
                    "entry": "system.info",
                    "perm": "x"
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
