{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — firewall module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "firewall.add_rule",
      "summary": "add firewall rule",
      "params": [
        {
          "name": "name",
          "schema": {
            "type": "string",
            "description": "rule's name"
          },
          "required": false
        },
        {
          "name": "src",
          "schema": {
            "type": "string",
            "description": "source zone(get from get_zone_list)"
          },
          "required": false
        },
        {
          "name": "src_ip",
          "schema": {
            "type": "string",
            "description": "source IP address"
          },
          "required": false
        },
        {
          "name": "src_mac",
          "schema": {
            "type": "string",
            "description": "source MAC address"
          },
          "required": false
        },
        {
          "name": "src_port",
          "schema": {
            "type": "number",
            "description": "src port(1 ~ 65535)"
          },
          "required": false
        },
        {
          "name": "proto",
          "schema": {
            "type": "string",
            "description": "protocol [{tcp udp}: {default}; {tcp}; {udp}]"
          },
          "required": false
        },
        {
          "name": "dest",
          "schema": {
            "type": "string",
            "description": "destination zone(get from get_zone_list)"
          },
          "required": false
        },
        {
          "name": "dest_ip",
          "schema": {
            "type": "string",
            "description": "destination IP address"
          },
          "required": false
        },
        {
          "name": "dest_port",
          "schema": {
            "type": "number",
            "description": "destination port(1 ~ 65535)"
          },
          "required": false
        },
        {
          "name": "enabled",
          "schema": {
            "type": "boolean",
            "description": "whether to enbale this rule"
          },
          "required": false
        },
        {
          "name": "target",
          "schema": {
            "type": "string",
            "description": "action [{ACCEPT}, {REJECT}, {DROP}]"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "rule's ID"
            }
          }
        }
      },
      "examples": [
        {
          "name": "add_rule_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "firewall",
                  "add_rule",
                  {
                    "name": "test",
                    "src": "wan",
                    "dest_port": 22,
                    "target": "ACCEPT"
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "id": "cfg1392bd"
            }
          }
        }
      ]
    },
