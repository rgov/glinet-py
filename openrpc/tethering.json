{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — tethering module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "tethering.get_status",
      "summary": "get tethering info",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "devices": {
              "type": "array",
              "description": "device list",
              "items": {
                "type": "object",
                "properties": {
                  "device": {
                    "type": "string",
                    "description": "device name"
                  },
                  "type": {
                    "type": "number",
                    "description": "device type [0: Android; 1:Apple; 2:unknow]",
                    "oneOf": [
                      {
                        "const": 0,
                        "title": "Android"
                      },
                      {
                        "const": 1,
                        "title": "Apple"
                      },
                      {
                        "const": 2,
                        "title": "unknow"
                      }
                    ]
                  },
                  "use": {
                    "type": "boolean",
                    "description": "working status [ture: enable; false: disable]"
                  }
                }
              }
            },
            "status": {
              "type": "number",
              "description": "device status [0: disconnected; 1: connected; 2: connecting]",
              "oneOf": [
                {
                  "const": 0,
                  "title": "disconnected"
                },
                {
                  "const": 1,
                  "title": "connected"
                },
                {
                  "const": 2,
                  "title": "connecting"
                }
              ]
            },
            "ipv6": {
              "type": "object",
              "description": "IPv6 info",
              "properties": {
                "ip": {
                  "type": "string",
                  "description": "IPv6 address"
                },
                "gateway": {
                  "type": "string",
                  "description": "IPv6 gateway"
                },
                "dns": {
                  "type": "array",
                  "description": "IPv6 DNS"
                }
              }
            },
            "ipv4": {
              "type": "object",
              "description": "IPv4 info",
              "properties": {
                "ip": {
                  "type": "string",
                  "description": "IPv4 address"
                },
                "gateway": {
                  "type": "string",
                  "description": "IPv4 gateway"
                },
                "dns": {
                  "type": "array",
                  "description": "IPv4 DNS"
                }
              }
            },
            "err_code": {
              "type": "number",
              "description": "error code [-1: This feature is not supported; -2: The device is not plugged in]",
              "oneOf": [
                {
                  "const": -1,
                  "title": "This feature is not supported"
                },
                {
                  "const": -2,
                  "title": "The device is not plugged in"
                }
              ]
            },
            "err_msg": {
              "type": "string",
              "description": "error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_status_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "tethering",
                  "get_status",
                  {}
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "devices": [
                {
                  "name": "usb0",
                  "tyep": 0,
                  "use": true
                },
                {
                  "device": "usb1",
                  "tyep": 0,
                  "use": false
                }
              ],
              "status": 1,
              "ipv4": {
                "ip": "192.168.42.38/24",
                "gateway": "192.168.42.129",
                "dns": [
                  "192.168.42.129"
                ]
              }
            }
          }
        }
      ]
    },
    {
      "name": "tethering.set_connect",
      "summary": "connect or disconnect tethering",
      "params": [
        {
          "name": "device",
          "schema": {
            "type": "string",
            "description": "device name"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "error code [-3: missing parameters]"
            },
            "err_msg": {
              "type": "string",
              "description": "error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_connect_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "tethering",
                  "set_connect",
                  {
                    "device": "usb0"
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
    {
      "name": "tethering.disconnect",
      "summary": "disconnect tethering",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "null",
            "object"
          ]
        }
      },
      "examples": [
        {
          "name": "disconnect_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "tethering",
                  "disconnect"
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
    {
      "name": "tethering.get_config",
      "summary": "(undocumented — discovered in SPA bundle)",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "array"
        }
      },
      "x-source": "live-probed"
    }
  ]
}