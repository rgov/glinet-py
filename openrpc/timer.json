    {
      "name": "timer.set_wifi",
      "summary": "set wifi config",
      "params": [
        {
          "name": "wifi",
          "schema": {
            "type": "array",
            "description": "set the group data of WiFi schedule",
            "items": {
              "type": "object",
              "properties": {
                "enable": {
                  "type": "boolean",
                  "description": "set the status of WiFi schedule [true: enable; false: disable]"
                },
                "band": {
                  "type": "string",
                  "description": "set the WiFi band [2g; 5g]"
                },
                "guest": {
                  "type": "number",
                  "description": "set the WiFi type [0: main WiFi; 1: guest WiFi]",
                  "oneOf": [
                    {
                      "const": 0,
                      "title": "main WiFi"
                    },
                    {
                      "const": 1,
                      "title": "guest WiFi"
                    }
                  ]
                },
                "func": {
                  "type": "string",
                  "description": "set the WiFi schedule function, turn_onoff refer to turn on and off the WiFi, power_switch refer to switch the WiFi transmission power"
                },
                "turnon_hour": {
                  "type": "string",
                  "description": "set the start time (hour) of WiFi schedule, required when set as turn_onoff"
                },
                "turnon_min": {
                  "type": "string",
                  "description": "set the start time (minute) of WiFi schedule, required when set as turn_onoff"
                },
                "turnoff_hour": {
                  "type": "string",
                  "description": "set the end time (hour) of WiFi schedule, required when set as turn_onoff"
                },
                "turnoff_min": {
                  "type": "string",
                  "description": "set the end time (minute) of WiFi schedule, required when set as turn_onoff"
                },
                "switch_hour": {
                  "type": "string",
                  "description": "set the time (hour) to switch the transmission power, required when set as power_switch"
                },
                "switch_min": {
                  "type": "string",
                  "description": "set the time (minute) to switch the transmission power, required when set as power_switch"
                },
                "restore_hour": {
                  "type": "string",
                  "description": "set the time (hour) to switch back the transmission power, required when set as power_switch"
                },
                "restore_min": {
                  "type": "string",
                  "description": "set the time (minute) to switch back the transmission power, required when set as power_switch"
                },
                "switch_power": {
                  "type": "string",
                  "description": "set the transmission power switch to, required when set as power_switch [ Max; High; Medium; Low]"
                },
                "restore_power": {
                  "type": "string",
                  "description": "set the transmission power switch back to, required when set as power_switch [ Max; High; Medium; Low]"
                },
                "week": {
                  "type": "array",
                  "description": "set the days to perform WiFi schedule in a week"
                }
              }
            }
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_msg": {
              "type": "string",
              "description": "error message"
            },
            "err_code": {
              "type": "number",
              "description": "error code [-1: parameter error]"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_wifi_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "timer",
                  "set_wifi",
                  {
                    "wifi": [
                      {
                        "band": "5G",
                        "turnoff_min": "11",
                        "enable": false,
                        "func": "turn_onoff",
                        "turnoff_hour": "11",
                        "guest": "0",
                        "week": [
                          0,
                          1
                        ],
                        "turnon_min": "11",
                        "turnon_hour": "11"
                      },
                      {
                        "band": "5G",
                        "turnoff_min": "11",
                        "enable": false,
                        "func": "turn_onoff",
                        "turnoff_hour": "11",
                        "guest": "1",
                        "week": [
                          0,
                          1
                        ],
                        "turnon_min": "11",
                        "turnon_hour": "11"
                      }
                    ]
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
