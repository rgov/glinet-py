{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — timer module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "timer.set_led",
      "summary": "set led config",
      "params": [
        {
          "name": "enable",
          "schema": {
            "type": "boolean",
            "description": "set the LED schedule status [true: enable; false: disable]"
          },
          "required": true
        },
        {
          "name": "turnon_hour",
          "schema": {
            "type": "string",
            "description": "set the start time (hour) of LED schedule"
          },
          "required": true
        },
        {
          "name": "turnon_min",
          "schema": {
            "type": "string",
            "description": "set the start time (minute) of LED schedule"
          },
          "required": true
        },
        {
          "name": "turnoff_hour",
          "schema": {
            "type": "string",
            "description": "set the end time (hour) of LED schedule"
          },
          "required": true
        },
        {
          "name": "turnoff_min",
          "schema": {
            "type": "string",
            "description": "set the end time (minute) of LED schedule"
          },
          "required": true
        },
        {
          "name": "week",
          "schema": {
            "type": "array",
            "description": "set the days to perfrom the LED schedule in a week"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "error code [-1: parameter error]"
            },
            "err_msg": {
              "type": "string",
              "description": "error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_led_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "timer",
                  "set_led",
                  {
                    "enable": true,
                    "turnon_hour": "07",
                    "turnon_min": "00",
                    "turnoff_hour": "22",
                    "turnoff_min": "00"
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
