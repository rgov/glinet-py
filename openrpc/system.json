                  "interface": "modem_1_1_2"
                }
              ],
              "wifi": [
                {
                  "guest": false,
                  "ssid": "GL-XE300-49a",
                  "up": true,
                  "channel": 0,
                  "band": "2G",
                  "name": "default_radio0",
                  "passwd": "goodlife"
                },
                {
                  "guest": true,
                  "ssid": "GL-XE300-49a-Guest",
                  "up": false,
                  "channel": 0,
