                },
                {
                  "name": "ovpnclient",
                  "status": 0
                },
                {
                  "name": "ovpnserver",
                  "status": 0
                },
                {
                  "name": "tor",
                  "status": 0
                }
              ],
              "client": [
                {
                  "wireless_total": 0,
                  "cable_total": 1
                }
              ],
              "system": {
                "lan_ip": "192.168.8.1",
                "lan_netmask": "255.255.255.0",
                "guest_ip": "192.168.9.1",
