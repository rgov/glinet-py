{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — system module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "system.set_password",
      "summary": "Set administrator password for the device.",
      "params": [
        {
          "name": "username",
          "schema": {
            "type": "string",
            "description": "Username."
          },
          "required": true
        },
        {
          "name": "old_password",
          "schema": {
            "type": "string",
            "description": "Old password, which is the password currently in use."
          },
          "required": false
        },
        {
          "name": "new_password",
          "schema": {
            "type": "string",
            "description": "New password."
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code [-1: No permission; -2: Command not found, -3: Other unknown error]",
              "oneOf": [
                {
                  "const": -1,
                  "title": "No permission"
                },
                {
                  "const": -2,
                  "title": "Command not found"
                },
                {
                  "const": -3,
                  "title": "Other unknown error"
                }
              ]
            },
            "err_msg": {
              "type": "string",
              "description": "Error message."
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_password_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "system",
                  "set_password",
                  {
                    "username": "admin",
                    "old_password": "123",
                    "new_password": "456"
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
    },
    {
      "name": "system.get_status",
      "summary": "Get the basic status of system, network, services, etc.",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "system": {
              "type": "object",
              "description": "Basic status information of the system.",
              "properties": {
                "mode": {
                  "type": "number",
                  "description": "Working mode of the system [0: router mode; 1: WDS mode; 2: relay (extender) mode; 3: mesh mode; 4: access point mode; 5: unknown; 6: passthrough mode] , default is 0.",
                  "oneOf": [
                    {
                      "const": 0,
                      "title": "router mode"
                    },
                    {
                      "const": 1,
                      "title": "WDS mode"
                    },
                    {
                      "const": 2,
                      "title": "relay (extender) mode"
                    },
                    {
                      "const": 3,
                      "title": "mesh mode"
                    },
                    {
                      "const": 4,
                      "title": "access point mode"
                    },
                    {
                      "const": 5,
                      "title": "unknown"
                    },
                    {
                      "const": 6,
                      "title": "passthrough mode"
                    }
                  ]
                },
                "timestamp": {
                  "type": "number",
                  "description": "System timestamp (Unit: Seconds)."
                },
                "tzoffset": {
                  "type": "string",
                  "description": "System time-zone offset."
                },
                "uptime": {
                  "type": "number",
                  "description": "System uptime (Unit: Seconds)."
                },
                "load_average": {
                  "type": "array",
                  "description": "CPU load averages in system. it returns an array, the array is fixed with 3 numbers that represent the average load of 1, 5, and 15 minutes in sequence.",
                  "items": {
                    "type": "number"
                  }
                },
                "memory_total": {
                  "type": "number",
                  "description": "Total memory in the system (Unit: Byte)."
                },
                "memory_free": {
                  "type": "number",
                  "description": "Free memory in the system (Unit: Byte)."
                },
                "memory_buff_cache": {
                  "type": "number",
                  "description": "Buffered memory and cached memory in the system (Unit: Byte)."
                },
                "flash_total": {
                  "type": "number",
                  "description": "Total flash storage space in the system (Unit: Byte)."
                },
                "flash_free": {
                  "type": "number",
                  "description": "Available flash storage space in the system (Unit: Byte)."
                },
                "flash_app": {
                  "type": "number",
                  "description": "The flash storage space used by the application in the system (Unit: Byte)."
                },
                "lan_ip": {
                  "type": "string",
                  "description": "LAN IP."
                },
                "lan_netmask": {
                  "type": "string",
                  "description": "Subnet mask of LAN."
                },
                "guest_ip": {
                  "type": "string",
                  "description": "GUEST IP."
                },
                "guest_netmask": {
                  "type": "string",
                  "description": "Subnet mask of Guest."
                },
                "ipv6_enabled": {
                  "type": "boolean",
                  "description": "Enabled status of IPv6 service."
                },
                "ddns_enabled": {
                  "type": "boolean",
                  "description": "Enabled status of DDNS service."
                },
                "netnat_enabled": {
                  "type": "boolean",
                  "description": "Enabled status of hardware acceleration service."
                },
                "mcu": {
                  "type": "object",
                  "description": "Status of mcu in the system.",
                  "properties": {
                    "temperature": {
                      "type": "number",
                      "description": "Battery temperature."
                    },
                    "charge_percent": {
                      "type": "number",
                      "description": "Battery percentage."
                    },
                    "charging_status": {
                      "type": "number",
                      "description": "Battery charging status[0: not charged; 1: charging].",
                      "oneOf": [
                        {
                          "const": 0,
                          "title": "not charged"
                        },
                        {
                          "const": 1,
                          "title": "charging"
                        }
                      ]
                    },
                    "charge_cnt": {
                      "type": "number",
                      "description": "Total of battery charge cycles."
                    }
                  }
                },
                "cpu": {
                  "type": "object",
                  "properties": {
                    "temperature": {
                      "type": "number"
                    }
                  }
                }
              }
            },
            "network": {
              "type": "array",
              "description": "Status of network interfaces in the system.",
              "items": {
                "type": "object",
                "properties": {
                  "interface": {
                    "type": "string",
                    "description": "Network interface name."
                  },
                  "up": {
                    "type": "boolean",
                    "description": "Up status of the network interface"
                  },
                  "online": {
                    "type": "boolean",
                    "description": "Whether the network interface has access to the Internet"
                  }
                }
              }
            },
            "service": {
              "type": "array",
              "description": "Working status of system services, including VPN, AdguardHome, etc.",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Service name"
                  },
                  "status": {
                    "type": "number",
                    "description": "Enabled status of the service [0: Disabled; 1: Connected/Running; 2: Enabled but Connecting].",
                    "oneOf": [
                      {
                        "const": 0,
                        "title": "Disabled"
                      },
                      {
                        "const": 1,
                        "title": "Connected/Running"
                      },
                      {
                        "const": 2,
                        "title": "Enabled but Connecting"
                      }
                    ]
                  },
                  "group_id": {
                    "type": "number",
                    "description": "The group_id of the group to which the currently used OpenVPN or WireGuard client configuration file belongs."
                  },
                  "client_id": {
                    "type": "number",
                    "description": "The client_id of the currently used OpenVPN client configuration file."
                  },
                  "peer_id": {
                    "type": "number",
                    "description": "The peer_id of the currently used WireGuard client configuration file."
                  }
                }
              }
            },
            "wifi": {
              "type": "array",
              "description": "Basic Wi-Fi status of the system.",
              "items": {
                "type": "object",
                "properties": {
                  "ssid": {
                    "type": "string",
                    "description": "SSID of the Wi-Fi."
                  },
                  "name": {
                    "type": "string",
                    "description": "Interface name of the Wi-Fi, as a unique identifier for the Wi-Fi."
                  },
                  "band": {
                    "type": "string",
                    "description": "Band of the Wi-Fi [2G: 2.4GHz; 5G: 5GHz]."
                  },
                  "channel": {
                    "type": "number",
                    "description": "Channel of the Wi-Fi (0 is auto)."
                  },
                  "guest": {
                    "type": "boolean",
                    "description": "Whether the Wi-Fi belongs to the guest network."
                  },
                  "up": {
                    "type": "boolean",
                    "description": "Enabled status of the Wi-Fi."
                  },
                  "passwd": {
                    "type": "string",
                    "description": "Password of the Wi-Fi."
                  }
                }
              }
            },
            "client": {
              "type": "array",
              "description": "Total number of online clients.",
              "items": {
                "type": "object",
                "properties": {
                  "cable_total": {
                    "type": "number",
                    "description": "The total number of wired clients online."
                  },
                  "wireless_total": {
                    "type": "number",
                    "description": "The total number of wireless clients online."
                  }
                }
              }
            },
            "err_code": {
              "type": "number",
              "description": "Error code [-1: Failed to get information]."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_status_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "system",
                  "get_status"
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "network": [
                {
                  "online": false,
                  "up": false,
                  "interface": "wan"
                },
                {
                  "online": false,
                  "up": false,
