    {
      "name": "mwan3.get_status",
      "summary": "get mwan3 status [if this interface does not enable in mwan3, read the interface status directly instead of reading from mwan3]",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "interfaces": {
              "type": "array",
              "description": "interface setting",
              "items": {
                "type": "object",
                "properties": {
                  "interface": {
                    "type": "string",
                    "description": "interface name"
                  },
                  "status_v4": {
                    "type": "number",
                    "description": "interface ipv4 status [0: online; 1: offline; 2: error]",
                    "oneOf": [
                      {
                        "const": 0,
                        "title": "online"
                      },
                      {
                        "const": 1,
                        "title": "offline"
                      },
                      {
                        "const": 2,
                        "title": "error"
                      }
                    ]
                  },
                  "percent_v4": {
                    "type": "number",
                    "description": "ipv4 percentage"
                  },
                  "status_v6": {
                    "type": "number",
                    "description": "interface ipv6 status [0: online; 1: offline; 2: error]",
                    "oneOf": [
                      {
                        "const": 0,
                        "title": "online"
                      },
                      {
                        "const": 1,
                        "title": "offline"
                      },
                      {
                        "const": 2,
                        "title": "error"
                      }
                    ]
                  },
                  "percent_v6": {
                    "type": "number",
                    "description": "ipv6 percentage"
                  }
                }
              }
            },
            "err_code": {
              "type": "number",
              "description": "error code"
            },
            "err_msg": {
              "type": "string",
              "description": "error messag"
            }
          }
        }
