              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "vpn-policy",
                  "get_global_policy",
                  {}
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "kill_switch": 0,
              "wan_access": 0,
              "service_policy": 1
            }
          }
        }
      ]
