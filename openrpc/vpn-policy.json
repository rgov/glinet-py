      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "kill_switch": {
              "type": "number",
              "description": "Whether to block non-VPN traffic (0: not block, 1: block)"
            },
            "wan_access": {
              "type": "number",
              "description": "Whether to allow LAN->WAN forwarding traffic (0: not allow, 1: allow)"
            },
            "service_policy": {
              "type": "number",
              "description": "Whether to enable glinet service to use VPN of (0: enable 1: disable)"
            },
            "vpn_server_policy": {
              "type": "number",
              "description": "VPN cascading (0: enable 1: disable)"
            },
            "err_code": {
              "type": "number",
              "description": "Error Code"
            },
            "err_msg": {
              "type": "string",
              "description": "Error Message"
            }
          }
        }
