      "name": "vpn-policy.set_proxy_mode",
      "summary": "set proxy mode",
      "params": [
        {
          "name": "mode",
          "schema": {
            "type": "number",
            "description": "Proxy mode (0: global proxy, 1: automatic detection route, 2: custom route, 3: based on IP/domain, 4: based on client device MAC, 5: based on VLAN, ie. lan/guest interface)"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error Code(-1: parameter missing)"
            },
            "err_msg": {
              "type": "string",
              "description": "Error Message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_proxy_mode_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "vpn-policy",
                  "set_proxy_mode",
                  {
                    "mode": 0
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
