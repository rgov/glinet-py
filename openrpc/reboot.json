{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — reboot module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "reboot.set_config",
      "summary": "Set reboot config.",
      "params": [
        {
          "name": "enable",
          "schema": {
            "type": "boolean",
            "description": "Set the status of schedule reboot [true: enable; false: disable]"
          },
          "required": true
        },
        {
          "name": "hour",
          "schema": {
            "type": "string",
            "description": "Set the time (hour) to perfrom schedule reboot"
          },
          "required": true
        },
        {
          "name": "min",
          "schema": {
            "type": "string",
            "description": "Set the time (minute) to perfrom schedule reboot"
          },
          "required": true
        },
        {
          "name": "week",
          "schema": {
            "type": "array",
            "description": "Set the days to perfrom the LED schedule in a week"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code,-1;parameter error."
            },
            "err_msg": {
              "type": "string",
              "description": "\tError message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "reboot",
                  "set_config",
                  {
                    "enable": true,
                    "hour": "03",
                    "min": "00",
                    "week": [
                      0,
                      1,
                      2,
                      3,
                      4,
                      5,
                      6
                    ]
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
    {
      "name": "reboot.get_config",
      "summary": "Get config of reboot.",
      "params": [
        {
          "name": "enable",
          "schema": {
            "type": "boolean",
            "description": "Set the status of schedule reboot [true: enable; false: disable]"
          },
          "required": true
        },
        {
          "name": "hour",
          "schema": {
            "type": "string",
            "description": "Set the time (hour) to perfrom schedule reboot"
          },
          "required": true
        },
        {
          "name": "min",
          "schema": {
            "type": "string",
            "description": "Set the time (minute) to perfrom schedule reboot"
          },
          "required": true
        },
        {
          "name": "week",
          "schema": {
            "type": "array",
            "description": "Set the days to perfrom the LED schedule in a week"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "null",
            "object"
          ],
          "properties": {
            "enable": {
              "type": "boolean"
            },
            "week": {
              "type": "array",
              "items": {
                "type": "number"
              }
            },
            "hour": {
              "type": "string"
            },
            "min": {
              "type": "string"
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "reboot",
                  "get_config",
                  {}
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "enable": false,
              "week": [
                0,
                1,
                2,
                3,
                4,
                5,
                6
              ],
              "hour": "07",
              "min": "00"
            }
          }
        }
      ]
    }
  ]
}