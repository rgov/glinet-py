{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — nas-web module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "nas-web.get_proto_config",
      "summary": "get nas proto conf",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "res": {
              "type": "array",
              "description": "all proto config array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "proto name"
                  },
                  "enable": {
                    "type": "boolean",
                    "description": "proto if enable"
                  },
                  "port": {
                    "type": "number",
                    "description": "listen port"
                  },
                  "wan_access": {
                    "type": "boolean",
                    "description": "if wan access"
                  },
                  "ssl_enable": {
                    "type": "boolean",
                    "description": "webdav ssl enable"
                  },
                  "media_dir": {
                    "type": "string",
                    "description": "dlna media dir"
                  }
                }
              }
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_proto_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "nas-web",
                  "get_proto_config",
                  {}
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "res": [
                {
                  "name": "webdav",
                  "enable": true,
                  "port": 6009,
                  "wan_access": true
                }
              ]
            }
          }
        }
      ]
    },
