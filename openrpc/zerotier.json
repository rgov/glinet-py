{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — zerotier module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "zerotier.get_config",
      "summary": "Get zerotier settings",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "zerotier network id"
            },
            "enabled": {
              "type": "boolean",
              "description": "Whether to enable zerotier"
            },
            "lan_enabled": {
              "type": "boolean",
              "description": "Whether to enable lan side access"
            },
            "wan_enabled": {
              "type": "boolean",
              "description": "Whether to enable wan side access"
            },
            "err_code": {
              "type": "number",
              "description": "Error code,-1:Failed to get settings."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            },
            "enable": {
              "type": "boolean"
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "zerotier",
                  "get_config"
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "id": "22222222",
              "enable": true,
              "lan_enabled": true,
              "wan_enabled": false
            }
          }
        }
      ]
    },
    {
      "name": "zerotier.set_config",
      "summary": "Set zerotier settings",
      "params": [
        {
          "name": "lan_enabled",
          "schema": {
            "type": "boolean",
            "description": "Whether to allow lan side access: false: Disable, true：Enable"
          },
          "required": true
        },
        {
          "name": "wan_enabled",
          "schema": {
            "type": "boolean",
            "description": "Whether to allow lan side access: false: Disable, true：Enable"
          },
          "required": true
        },
        {
          "name": "enabled",
          "schema": {
            "type": "boolean",
            "description": "Status of zerotier：false :Disable， true：Enable"
          },
          "required": true
        },
        {
          "name": "id",
          "schema": {
            "type": "string",
            "description": "zerotier network id"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code,-1:illegal parameter."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "zerotier",
                  "set_config",
                  {
                    "enabled": true,
                    "lan_enabled": true,
                    "wan_enabled": true,
                    "id": "1234679862"
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
    },
    {
      "name": "zerotier.get_status",
      "summary": "Get zerotier status",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "number",
              "description": "0:connection succeeded, 1:connecting, 2:unauthorized, 3:The network id was not found"
            },
            "zerotier_ip": {
              "type": "string",
              "description": "After the connection is successful, return the zerotier server ip"
            },
            "lan_ip": {
              "type": "string",
              "description": "Enable to allow lan side access and return lan ip"
            },
            "wan_ip": {
              "type": "string",
              "description": "Enable to allow wan side access and return wan ip"
            },
            "secondwan_ip": {
              "type": "string",
              "description": "Enable to allow wan side access and return secondwan ip"
            },
            "wwan_ip": {
              "type": "string",
              "description": "Enable to allow wan side access and return wwan ip"
            },
            "err_code": {
              "type": "number",
              "description": "Error code,-1:Failed to get settings."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": []
    }
  ]
}