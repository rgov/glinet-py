{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — qos module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "qos.set_channel_bandwidth_ratio",
      "summary": "Configure priority channel bandwidth ratio",
      "params": [
        {
          "name": "sync_ratio",
          "schema": {
            "type": "boolean",
            "description": "sync upload bandwidth ratio to download bandwidth ratio"
          },
          "required": true
        },
        {
          "name": "upload",
          "schema": {
            "type": "array",
            "description": "upload bandwidth configuration",
            "items": {
              "type": "object",
              "properties": {
                "priority": {
                  "type": "number",
                  "description": "upload bandwidth priority"
                },
                "min": {
                  "type": "number",
                  "description": "The minimum upload bandwidth corresponding to the priority"
                },
                "max": {
                  "type": "number",
                  "description": "The maximum upload bandwidth corresponding to the priority"
                }
              }
            }
          },
          "required": true
        },
        {
          "name": "download",
          "schema": {
            "type": "array",
            "description": "download bandwidth configuration[only needed when sync_ratio is false]",
            "items": {
              "type": "object",
              "properties": {
                "priority": {
                  "type": "number",
                  "description": "download bandwidth priority"
                },
                "min": {
                  "type": "number",
                  "description": "The minimum download bandwidth corresponding to the priority"
                },
                "max": {
                  "type": "number",
                  "description": "The maximum download bandwidth corresponding to the priority"
                }
              }
            }
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code, -1:Invalid user,-5:No parameter found"
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_channel_bandwidth_ratio_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "id": 1,
                "params": [
                  "",
                  "qos",
                  "set_channel_bandwidth_ratio",
                  {
                    "sync_ratio": true,
                    "upload": [
                      {
                        "min": "90",
                        "priority": "1",
                        "max": "70"
                      },
                      {
                        "min": "70",
                        "priority": "2",
                        "max": "50"
                      },
                      {
                        "min": "45",
                        "priority": "3",
                        "max": "30"
                      },
                      {
                        "min": "25",
                        "priority": "4",
                        "max": "15"
                      }
                    ]
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
    },
