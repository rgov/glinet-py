{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — bark module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "bark.get_status",
      "summary": "Get bark status",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "number",
              "description": "The current status of the running router client, [1：connecting; 2: ready; 3: online]",
              "oneOf": [
                {
                  "const": 2,
                  "title": "ready"
                },
                {
                  "const": 3,
                  "title": "online"
                }
              ]
            },
            "pairing_code": {
              "type": "string",
              "description": "Pairing code between device and bark account"
            },
            "err_code": {
              "type": "number",
              "description": "Error code,-1:Failed to get status."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_status_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "bark",
                  "get_status"
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "status": 3,
              "pairing_code": "945712135847788"
            }
          }
        }
      ]
    },
    {
      "name": "bark.get_config",
      "summary": "Get bark settings",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "enable": {
              "type": "boolean",
              "description": "Whether bark router client is enabled，[false：disable; true：enable]"
            },
            "ipv6_enable": {
              "type": "boolean",
              "description": "Whether IPv6 support is enabled, [false：disable; true：enable]"
            },
            "err_code": {
              "type": "number",
              "description": "Error code,-1:Failed to get config."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "bark",
                  "get_config"
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "ipv6_enable": false,
              "enable": true
            }
          }
        }
      ]
    },
    {
      "name": "bark.set_config",
      "summary": "Set bark settings",
      "params": [
        {
          "name": "enable",
          "schema": {
            "type": "boolean",
            "description": "Whether to enable bark router client，[false：disable; true：enable]"
          },
          "required": true
        },
        {
          "name": "ipv6_enable",
          "schema": {
            "type": "boolean",
            "description": "Whether to enable IPv6 support, [false：disable; true：enable]"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code, -1:Setup failed"
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "bark",
                  "set_config",
                  {
                    "enable": true,
                    "ipv6_enable": true
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
    },
    {
      "name": "bark.logout",
      "summary": "Logout from current bark account",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code,-1:Logout failed."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "logout_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "bark",
                  "logout"
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
    }
  ]
}