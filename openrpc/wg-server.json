{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — wg-server module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "wg-server.get_peer_list",
      "summary": "Get the peer list of the wireguard client",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "peers": {
              "type": "array",
              "description": "peer array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "name"
                  },
                  "client_ip": {
                    "type": "string",
                    "description": "client tunnel ip"
                  },
                  "dns": {
                    "type": "string",
                    "description": "dns"
                  },
                  "allowed_ips": {
                    "type": "string",
                    "description": "allowed IP"
                  },
                  "end_point": {
                    "type": "string",
                    "description": "not used"
                  },
                  "listen_port": {
                    "type": "number",
                    "description": "listen port"
                  },
                  "persistent_keepalive": {
                    "type": "number",
                    "description": "keepalive interval"
                  },
                  "private_key": {
                    "type": "string",
                    "description": "private key"
                  },
                  "public_key": {
                    "type": "string",
                    "description": "public key"
                  },
                  "mtu": {
                    "type": "number",
                    "description": "MTU"
                  },
                  "peer_id": {
                    "type": "number",
                    "description": "peer id"
                  },
                  "presharedkey_enable": {
                    "type": "boolean",
                    "description": "enable presharedkey"
                  },
                  "presharedkey": {
                    "type": "number",
                    "description": "preshared key"
                  },
                  "deprecated": {
                    "type": "number",
                    "description": "whether the peer is available (0: available 1: unavailable)"
                  }
                }
              }
            },
            "err_code": {
              "type": "number",
              "description": "Error Code"
            },
            "err_msg": {
              "type": "string",
              "description": "Error Message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_peer_list_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "wg-server",
                  "get_peer_list",
                  {}
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "peers": [
                {
                  "name": "sample",
                  "client_ip": "10.0.0.2/32",
                  "listen_port": 50436,
                  "private_key": "oOMRHz5wTf5Gq6TPnpXLKIOhy54wx5XO7/4nquChIFI=",
                  "dns": "64.6.64.6",
                  "end_point": "116.77.73.248:51820",
                  "public_key": "m7pNpcTJxf2gqpmgSa3dCMgY0c2nP5rXHV7ume0/uzs=",
                  "allowed_ips": "0.0.0.0/0",
                  "persistent_keepalive": 25,
                  "mtu": 1420,
                  "peer_id": 2844,
                  "presharedkey_enable": true,
                  "presharedkey": "wKaBacfDah7EXNzIq9AbpHso4NUncS6M7NKPViUWxc0=",
