{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — rs485 module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "rs485.read_modbus_data",
      "summary": "read modbus data",
      "params": [
        {
          "name": "device_id",
          "schema": {
            "type": "string",
            "description": "rs485 device id:1-247"
          },
          "required": true
        },
        {
          "name": "func_code",
          "schema": {
            "type": "string",
            "description": "func code"
          },
          "required": true
        },
        {
          "name": "reg_addr_h",
          "schema": {
            "type": "string",
            "description": "RS485 terminal device register address high 8 bits"
          },
          "required": true
        },
        {
          "name": "reg_addr_l",
          "schema": {
            "type": "string",
            "description": "RS485 terminal device register address low 8 bits"
          },
          "required": true
        },
        {
          "name": "reg_len",
          "schema": {
            "type": "string",
            "description": "Number of registers,16 bits for one"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "log": {
              "type": "array",
              "description": "rs485 debug log"
            },
            "err_code": {
              "type": "number",
              "description": "error code [-1: device busy; -2: read timeout; -3: no data read]",
              "oneOf": [
                {
                  "const": -1,
                  "title": "device busy"
                },
                {
                  "const": -2,
                  "title": "read timeout"
                },
                {
                  "const": -3,
                  "title": "no data read"
                }
              ]
            },
            "err_msg": {
              "type": "string",
              "description": "error message."
            }
          }
        }
      },
      "examples": [
        {
          "name": "read_modbus_data_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "rs485",
                  "read_modbus_data",
                  {
                    "device_id": "16",
                    "func_code": "03",
                    "reg_addr_h": "00",
                    "reg_addr_l": "00",
                    "reg_len": "02"
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "log": [
                "2023-07-30 18:27:44.436 Command ==>16 03 00000002 C72C",
                "2023-07-30 18:27:44.470 Response ==>16 03 0402D8013A 9D32"
              ]
            }
          }
        }
      ]
    },
    {
