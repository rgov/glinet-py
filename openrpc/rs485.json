    {
      "name": "rs485.set_forward_config",
      "summary": "set network forward config",
      "params": [
        {
          "name": "enable",
          "schema": {
            "type": "boolean",
            "description": "\t\t enable netwotk forward[true/false]"
          },
          "required": true
        },
        {
          "name": "protocol",
          "schema": {
            "type": "string",
            "description": "\t\t network protocl[socket/mqtt]"
          },
          "required": true
        },
        {
          "name": "type",
          "schema": {
            "type": "string",
            "description": "\t\t\t parse method[hex/str]"
          },
          "required": true
        },
        {
          "name": "address",
          "schema": {
            "type": "string",
            "description": "server address(only needed when work in tcpc/mqtt mode)"
          },
          "required": true
        },
        {
          "name": "port",
          "schema": {
            "type": "number",
            "description": "socket/mqtt server port[1-65535]"
          },
          "required": true
        },
        {
          "name": "enable_tls",
          "schema": {
            "type": "boolean",
            "description": "\t\t enable mqtt tls encryption"
          },
          "required": true
        },
        {
          "name": "encry_mode",
          "schema": {
            "type": "number",
            "description": "\t\t encryption mode [0:one way; 1: two way]",
            "oneOf": [
              {
                "const": 0,
                "title": "one way"
              },
              {
                "const": 1,
                "title": "two way"
              }
            ]
          },
          "required": true
        },
        {
          "name": "cacrt",
          "schema": {
            "type": "string",
            "description": "\t\t ca certificate"
          },
          "required": true
        },
        {
          "name": "clicrt",
          "schema": {
            "type": "string",
            "description": "client certificate"
          },
          "required": true
        },
        {
          "name": "clikey",
          "schema": {
            "type": "string",
            "description": "client key"
          },
          "required": true
        },
        {
          "name": "username",
          "schema": {
            "type": "string",
            "description": "mqtt username"
          },
          "required": true
        },
        {
          "name": "password",
          "schema": {
            "type": "string",
            "description": "mqtt password"
          },
          "required": true
        },
        {
          "name": "subscribe",
          "schema": {
            "type": "string",
            "description": "subscribe topics"
          },
          "required": true
        },
        {
          "name": "publish",
          "schema": {
            "type": "string",
            "description": "publish topics"
          },
          "required": true
        },
        {
          "name": "clientid",
          "schema": {
            "type": "string",
            "description": "mqtt clientid"
          },
          "required": true
        },
        {
          "name": "qos",
          "schema": {
            "type": "number",
            "description": "mqtt qos [0/1/2]"
          },
          "required": true
        },
        {
          "name": "interval",
          "schema": {
            "type": "number",
            "description": "mqtt heartbeat package inteval 0-65"
          },
          "required": true
        },
        {
          "name": "mode",
          "schema": {
            "type": "string",
            "description": "[tcps/tcpc/udp] as server or client"
          },
          "required": true
        },
        {
          "name": "timeout",
          "schema": {
            "type": "number",
            "description": "no communication within this time will disconnect :0-86400(s)"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "error code [-6: ERR_PARAMETER; -20: ERR_PORT]",
              "oneOf": [
                {
                  "const": -6,
                  "title": "ERR_PARAMETER"
                },
                {
                  "const": -20,
                  "title": "ERR_PORT"
                }
              ]
            },
            "err_msg": {
              "type": "string",
              "description": "[ca missing; port:80 is in using, suggest use 32768]"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_forward_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "rs485",
                  "set_forward_config",
                  {
                    "enable": true,
                    "protocol": "mqtt",
                    "type": "str",
                    "address": "broker.emqx.io",
                    "port": 1883,
                    "enable_tls": true,
                    "encry_mode": 1,
                    "cacrt": "-----BEGIN CERTIFICATE-----\n......\n-----END CERTIFICATE-----\n",
                    "clicrt": "-----BEGIN CERTIFICATE-----\n......\n-----END CERTIFICATE-----\n",
                    "clikey": "-----BEGIN RSA PRIVATE KEY-----\n......\n-----END RSA PRIVATE KEY-----\n",
                    "username": "test",
                    "password": "123456",
                    "publish": "/glinet/rs485/data",
                    "subscribe": "/glinet/rs485/cmd",
                    "clientid": "glinetx300b",
                    "qos": 0,
                    "interval": 60
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
