            },
            "err_code": {
              "type": "number",
              "description": "error code [-1: device busy; -2: read timeout; -3: no data read; -4: write data too long; -5: data format error]",
              "oneOf": [
                {
                  "const": -1,
                  "title": "device busy"
                },
                {
                  "const": -2,
                  "title": "read timeout"
                },
                {
                  "const": -3,
                  "title": "no data read"
                },
                {
                  "const": -4,
                  "title": "write data too long"
                },
                {
                  "const": -5,
                  "title": "data format error"
                }
              ]
            },
            "err_msg": {
              "type": "string",
              "description": "error message."
            }
          }
        }
      },
      "examples": [
        {
          "name": "write_modbus_data_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "rs485",
                  "write_modbus_data",
                  {
                    "device_id": "01",
                    "func_code": "04",
                    "reg_addr_h": "00",
                    "reg_addr_l": "00",
                    "reg_len": "02",
                    "data_w": "0000"
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "log": [
                "2023-07-31 06:59:56.156 Command ==>01 05 00000000 CDCA",
                "2023-07-31 06:59:56.156 Response ==>nodata"
              ]
            }
          }
        }
      ]
    },
