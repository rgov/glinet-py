    {
      "name": "parental-control.get_config",
      "summary": "Get parental control configuration.",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "enable": {
              "type": "boolean",
              "description": "Whether to enable or not."
            },
            "drop_anonymous": {
              "type": "boolean",
              "description": "Whether to prohibit anonymous device access."
            },
            "auto_update": {
              "type": "boolean",
              "description": "Whether to automatically update the feature library."
            },
            "enable_app": {
              "type": "boolean",
              "description": "Whether to enable the app feature library."
            },
            "rules": {
              "type": "array",
              "description": "List of rulesets, return if ruleset are not empty.",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Ruleset ID, globally unique, used to distinguish different rulesets."
                  },
                  "preset": {
                    "type": "boolean",
                    "description": "Whether it is a preset ruleset."
                  },
                  "name": {
                    "type": "string",
                    "description": "The name of the ruleset."
                  },
                  "color": {
                    "type": "string",
                    "description": "Label color of ruleset, used by UI."
                  },
                  "apps": {
                    "type": "array",
                    "description": "A list of application IDs contained in the ruleset, which is an integer type. The correspondence between applications and IDs is returned through the get_app_list."
                  },
                  "blacklist": {
                    "type": "array",
                    "description": "The exception list of the ruleset, which is a string type. This list is an exception relative to the apps parameter, and follows the application feature description syntax. For the application feature description syntax, please refer to doc.gl-inet.com."
                  }
                }
              }
            },
            "groups": {
              "type": "array",
              "description": "Device group list, if the group list is not empty, it will be returned.",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Group ID, globally unique, used to distinguish different device groups."
                  },
                  "name": {
                    "type": "string",
                    "description": "Group's name."
                  },
                  "default_rule": {
                    "type": "string",
                    "description": "The default ruleset ID used by the group. The ruleset ID must correspond to the ruleset ID returned in the rules parameter."
                  },
                  "macs": {
                    "type": "array",
                    "description": "A list of device MAC addresses contained in the group, which is a string type."
                  },
                  "schedules": {
                    "type": "array",
                    "description": "The list of schedules contained in the group. If there is a schedule setting for the corresponding group, this parameter will be returned.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "number",
                          "description": "Schedule's ID."
                        },
                        "week": {
                          "type": "number",
                          "description": "The day of the week, the allowable range is 0-6, corresponding to Saturday to Sunday."
                        },
                        "begin": {
                          "type": "string",
                          "description": "The start time of the schedule, the format is hh:mm, the start time must be before the end time."
                        },
                        "end": {
                          "type": "string",
                          "description": "The end time of the schedule, the format is hh:mm, the end time must be after the start time."
                        },
                        "rule": {
                          "type": "string",
                          "description": "The ID of the ruleset to be used by this schedule. The ID of the ruleset must correspond to the ID of the ruleset returned in the rules parameter."
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "parental-control",
                  "get_config"
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "enable": true,
              "drop_anonymous": false,
              "auto_update": false,
              "rules": [
                {
                  "id": "cfga067b",
                  "name": "rule1",
                  "color": "#aabbccddee",
                  "apps": [
                    1001,
                    2002
                  ],
                  "blacklist": [
                    "[tcp;;;www.google.com;;]"
                  ]
                },
                {
                  "id": "cfga067c",
                  "name": "rule2",
                  "color": "#aabbccddee",
                  "apps": [
                    3003,
                    4004
                  ],
                  "blacklist": [
                    "[tcp;;;www.google.com;;]"
                  ]
                }
              ],
              "groups": [
                {
                  "name": "group1",
                  "macs": [
                    "98:6B:46:F0:9B:A4",
                    "98:6B:46:F0:9B:A5"
                  ],
                  "default_rule": "cfga067a",
                  "schedules": [
                    {
                      "week": 1,
                      "begin": "12:00",
                      "end": "13:00",
                      "rule": "cfga067c",
                      "id": "cfga066c"
                    },
                    {
                      "date": 2,
