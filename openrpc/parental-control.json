                  "set_group",
                  {
                    "id": "cfga01234b",
                    "name": "group1",
                    "macs": [
                      "98:6B:46:F0:9B:A4",
                      "98:6B:46:F0:9B:A5"
                    ],
                    "default_rule": "cfga067b",
                    "schedules": [
                      {
                        "week": [
                          1,
                          3,
                          5
                        ],
                        "begin": "12:00",
                        "end": "13:00",
                        "rule": "cfga067c"
                      },
                      {
                        "date": 2,
                        "begin": "17:00",
                        "end": "18:00",
                        "rule": "cfga067c"
                      }
                    ]
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
    {
      "name": "parental-control.add_rule",
      "summary": "Add a ruleset.",
      "params": [
        {
          "name": "name",
          "schema": {
            "type": "string",
            "description": "The name of the ruleset, globally unique, used to distinguish different rulesets."
          },
          "required": true
        },
        {
          "name": "color",
          "schema": {
            "type": "string",
            "description": "The label color of the ruleset, which is used for displaying UI."
          },
          "required": true
        },
        {
          "name": "apps",
          "schema": {
            "type": "array",
            "description": "The ID or application type of the application included in the ruleset, which is an integer type, and the corresponding relationship between the application and the ID is returned through the get_app_list."
          },
          "required": true
        },
        {
          "name": "blacklist",
          "schema": {
            "type": "array",
            "description": "blacklist The blacklist list of the ruleset, which is a string type. This list follows the application feature description syntax. For the application feature description syntax, please refer to doc.gl-inet.com"
          },
          "required": false
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "number",
              "description": "ID of the new ruleset."
            },
            "err_code": {
              "type": "number",
              "description": "Error code (-1: missing required parameter, -2: domain name in blacklist is illegal)"
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "add_rule_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "parental-control",
                  "add_rule",
                  {
                    "name": "rule1",
                    "color": "#aabbccddee",
                    "apps": [
                      1001,
                      2002
                    ],
                    "blacklist": [
                      "[tcp;;;www.google.com;;]"
                    ]
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
