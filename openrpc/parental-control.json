    {
      "name": "parental-control.set_brief",
      "summary": "Set temporary ruleset.",
      "params": [
        {
          "name": "enable",
          "schema": {
            "type": "boolean",
            "description": "Whether to enable."
          },
          "required": true
        },
        {
          "name": "manual_stop",
          "schema": {
            "type": "boolean",
            "description": "Whether need manual stop."
          },
          "required": false
        },
        {
          "name": "time",
          "schema": {
            "type": "string",
            "description": "The duration of the temporary ruleset."
          },
