{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — parental-control module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "parental-control.get_app_list",
      "summary": "Get a list of recognized applications.",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "apps": {
              "type": "array",
              "description": "List of recognized applications.",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "number",
                    "description": "Application ID, globally unique, application ID starts from 1001, 0-1000 is a special ID, reserved for use, among which 1-8 is a type ID, if this ID is set, it means all applications under this type."
                  },
                  "name": {
                    "type": "string",
                    "description": "Application name."
                  },
                  "type": {
                    "type": "number",
                    "description": "Application type (1: social, 2: game, 3: video, 4: shopping, 5: music, 6: recruitment, 7: download, 8: portal)."
                  }
                }
              }
            }
          }
        }
      },
      "examples": []
    },
    {
      "name": "parental-control.add_group",
      "summary": "Add device group.",
      "params": [
        {
          "name": "name",
          "schema": {
            "type": "string",
            "description": "group name"
          },
          "required": true
        },
        {
          "name": "default_rule",
          "schema": {
            "type": "string",
            "description": "The default ruleset ID used by the group. The ruleset ID must correspond to the ruleset ID returned in the rules parameter."
          },
          "required": true
        },
        {
          "name": "macs",
          "schema": {
            "type": "array",
            "description": "The device MAC address list contained in the group, which is a string type."
          },
          "required": true
        },
        {
          "name": "schedules",
          "schema": {
            "type": "array",
            "description": "The list of schedules contained in the group. If there is a schedule setting for the corresponding group, enter this parameter.",
            "items": {
              "type": "object",
              "properties": {
                "week": {
                  "type": "number",
                  "description": "The day of the week for the schedule, the allowable range is 0-6, corresponding from Sunday to Saturday."
                },
                "begin": {
                  "type": "string",
                  "description": "The start time of the schedule, the format is hh:mm, the start time must be before the end time."
                },
                "end": {
                  "type": "string",
                  "description": "The end time of the schedule, the format is hh:mm, the end time must be after the start time."
                },
                "rule": {
                  "type": "string",
                  "description": "The ID of the ruleset to be used by this schedule. The ID of the ruleset must correspond to the ID of the ruleset entered in the rules parameter."
                }
              }
            }
          },
          "required": false
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "The ID of the new group"
            },
            "err_code": {
              "type": "number",
              "description": "Error code (-1: missing required parameters, -2: passed shedules but missing required parameters)"
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "add_group_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "parental-control",
                  "add_group",
                  {
                    "name": "group1",
                    "macs": [
                      "98:6B:46:F0:9B:A4",
                      "98:6B:46:F0:9B:A5"
                    ],
                    "default_rule": "cfga067b",
                    "schedules": [
                      {
                        "week": 1,
                        "begin": "12:00",
                        "end": "13:00",
                        "rule": "cfga067c"
                      },
                      {
                        "date": 2,
                        "begin": "17:00",
                        "end": "18:00",
                        "rule": "cfga067c"
                      }
                    ]
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "id": "cfga048"
            }
          }
        }
      ]
    },
    {
      "name": "parental-control.remove_group",
      "summary": "Remove a device group.",
      "params": [
        {
          "name": "id",
          "schema": {
            "type": "string",
            "description": "The ID of the group to be deleted. The ID of the group can be obtained through get_config."
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code (-1: missing required parameter)"
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "remove_group_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "parental-control",
                  "remove_group",
                  {
                    "id": "cfga01234b"
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
