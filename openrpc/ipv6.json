{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — ipv6 module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "ipv6.get_ipv6",
      "summary": "get ipv6 configuration information",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "enable": {
              "type": "boolean",
              "description": "Whether to enable ipv6."
            },
            "lan_mode": {
              "type": "string",
              "description": "Ipv6 mode [native;relay;nat6;static] (relay is displayed as Passthrough on the Web)."
            },
            "lan_ip": {
              "type": "string",
              "description": "When lan_mode is static, it is the IPv6 address of the LAN interface."
            },
            "lan_dns_mode": {
              "type": "boolean",
              "description": "Dns mode，'true' means auto, 'false' means manual."
            },
            "lan_dns1": {
              "type": "string",
              "description": "When lan_dnsmode is false, the first DNS server address of the LAN interface."
            },
            "lan_dns2": {
              "type": "string",
              "description": "When lan_dnsmode is false, the second DNS server address of the LAN interface."
            },
            "err_code": {
              "type": "number",
              "description": "Error code:-1:Information acquisition failure."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_ipv6_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "ipv6",
                  "get_ipv6"
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "enable": false,
              "lan_dns_mode": true,
              "lan_mode": "nat6"
            }
          }
        }
      ]
    },
    {
      "name": "ipv6.set_ipv6",
      "summary": "setting ipv6",
      "params": [
        {
          "name": "enable",
          "schema": {
            "type": "boolean",
            "description": "Whether to enable ipv6."
          },
          "required": true
        },
        {
          "name": "lan_mode",
          "schema": {
            "type": "string",
            "description": "Ipv6 mode [native;relay;nat6;static] (relay is displayed as Passthrough on the Web)."
          },
          "required": true
        },
        {
          "name": "lan_ip",
          "schema": {
            "type": "string",
            "description": "When lan_mode is static, it is the IPv6 address of the LAN interface."
          },
          "required": false
        },
        {
          "name": "lan_dns_mode",
          "schema": {
            "type": "boolean",
            "description": "Dns mode，'true' means auto, 'false' means manual."
          },
          "required": true
        },
        {
          "name": "lan_dns1",
          "schema": {
            "type": "string",
            "description": "When lan_dnsmode is false, the first DNS server address of the LAN interface."
          },
          "required": false
        },
        {
          "name": "lan_dns2",
          "schema": {
            "type": "string",
            "description": "When lan_dnsmode is false, the second DNS server address of the LAN interface."
          },
          "required": false
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_ipv6_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "ipv6",
                  "set_ipv6",
                  {
                    "enable": true,
                    "lan_mode": "static",
                    "lan_ip": "fdab:6a57:e8f5:10:d14f:d19b:a63c:d7a5",
                    "lan_dns_mode": true,
                    "lan_dns1": "fdab:6a57:e8f5:10::1",
                    "lan_dns2": "fdab:6a57:e8f5:10::2"
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
    }
  ]
}