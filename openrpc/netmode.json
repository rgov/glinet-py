{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — netmode module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "netmode.get_mode",
      "summary": "Query the current network mode",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "description": "current network mode"
            },
            "mask": {
              "type": "string",
              "description": "When switching to passthrough mode, the returned mask"
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_mode_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "netmode",
                  "get_mode"
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "mode": "router"
            }
          }
        }
      ]
    },
    {
      "name": "netmode.set_mode",
      "summary": "set network mode",
      "params": [
        {
          "name": "mode",
          "schema": {
            "type": "string",
            "description": "Network mode, optional values: ap, router, relay, wds, passthrough"
          },
          "required": true
        },
        {
          "name": "ssid",
          "schema": {
            "type": "string",
            "description": "SSID (required for relay and wds modes)"
          },
          "required": false
        },
        {
          "name": "identity",
          "schema": {
            "type": "string",
            "description": "EAP identity (required if WPA-Enterprise encryption)"
          },
          "required": false
        },
        {
          "name": "key",
          "schema": {
            "type": "string",
            "description": "password (required for relay and wds modes)"
          },
          "required": false
        },
        {
          "name": "mask",
          "schema": {
            "type": "string",
            "description": "Client IP mask bits (required for passthrough mode)"
          },
          "required": false
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "lanip": {
              "type": "string",
              "description": "When switching to routing mode, the returned lan ip"
            },
            "err_code": {
              "type": "number",
              "description": "error code: one: Connection failed, two: get IP failed, three: IP network segment conflict (the LAN interface must be set with an address that is not on the same network segment as the WiFi you want to connect to)"
            },
            "err_msg": {
              "type": "number",
              "description": "error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_mode_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "netmode",
                  "set_mode",
                  {
                    "mode": "router"
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
    }
  ]
}