{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — local-access module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "local-access.get_config",
      "summary": "Get configuration",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "redirect_https": {
              "type": "boolean",
              "description": "Whether to redirect http to https"
            },
            "http_port": {
              "type": "number",
              "description": "HTTP port"
            },
            "https_port": {
              "type": "number",
              "description": "HTTPS port"
            },
            "ssh_port": {
              "type": "number",
              "description": "SSH port"
            },
            "session_timeout": {
              "type": "number",
              "description": "Session timeout duration (unit: second)"
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "nginx",
                  "get_config",
                  {}
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "redirect_https": false,
              "http_port": 80,
              "https_port": 443,
              "session_timeout": 300
            }
          }
        }
      ]
    },
    {
      "name": "local-access.set_config",
      "summary": "Set configuration",
      "params": [
        {
          "name": "redirect_https",
          "schema": {
            "type": "boolean",
            "description": "Whether to redirect http to https"
          },
          "required": false
        },
        {
          "name": "http_port",
          "schema": {
            "type": "number",
            "description": "HTTP port"
          },
          "required": false
        },
        {
          "name": "https_port",
          "schema": {
            "type": "number",
            "description": "HTTPS port"
          },
          "required": false
        },
        {
          "name": "ssh_port",
          "schema": {
            "type": "number",
            "description": "SSH port"
          },
          "required": false
        },
        {
          "name": "session_timeout",
          "schema": {
            "type": "number",
            "description": "Session timeout duration (unit: second)"
          },
          "required": false
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "null",
            "object"
          ]
        }
      },
      "examples": [
        {
          "name": "set_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "nginx",
                  "set_config",
                  {
                    "redirect_https": false,
                    "http_port": 80,
                    "https_port": 443,
                    "session_timeout": 300
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
    }
  ]
}