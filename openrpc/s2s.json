{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — s2s module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "s2s.enable_echo_server",
      "summary": "enable echo listening server for testing",
      "params": [
        {
          "name": "port",
          "schema": {
            "type": "string",
            "description": "Set the server listening port"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code,-1:Parameter error,-2:File does not exist,-3:uci Initialization error."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "enable_echo_server_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "s2s",
                  "enable_echo_server",
                  {
                    "port": "51820"
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
    {
      "name": "s2s.generate_wg_genkey",
      "summary": "Generate a new private key and return its public key.",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "public_key": {
              "type": "string",
              "description": "Public key"
            },
            "err_code": {
              "type": "number",
              "description": "Error code,-3:uci Initialization error."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "generate_wg_genkey_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "s2s",
                  "generate_wg_genkey",
                  {}
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "public_key": "RYqIcKGF2Zs1obKDOqmxXH/WsnYn4/OwnExQXBgN7xE="
            }
          }
        }
      ]
    },
    {
      "name": "s2s.set_config",
      "summary": "Push the complete WireGuard settings file.",
      "params": [
        {
          "name": "lan_ip",
          "schema": {
            "type": "string",
            "description": "Lan ip."
          },
          "required": false
        },
        {
          "name": "restart",
          "schema": {
            "type": "boolean",
            "description": "Whether to restart the WireGuard service."
          },
          "required": false
        },
        {
          "name": "interface",
          "schema": {
            "type": "object",
            "description": "WireGuard interface information.",
            "properties": {
              "private_key": {
                "type": "string",
                "description": "Private key."
              },
              "address": {
                "type": "array",
                "description": "Address."
              },
              "listen_port": {
                "type": "string",
                "description": "Listening port."
              },
              "mtu": {
                "type": "string",
                "description": "Mtu."
              },
              "metric": {
                "type": "string",
                "description": "Metric."
              },
              "fwmark": {
                "type": "string",
                "description": "Fwmark."
              }
            }
          },
          "required": false
        },
        {
          "name": "peer",
          "schema": {
            "type": "array",
            "description": "Peer information of WireGuard.",
            "items": {
              "type": "object",
              "properties": {
                "public_key": {
                  "type": "string",
                  "description": "Public key."
                },
                "allowed_ips": {
                  "type": "array",
                  "description": "Encryption Key Routing."
                },
                "endpoint": {
                  "type": "string",
                  "description": "Endpoint."
                },
                "keepalive": {
                  "type": "string",
                  "description": "Keepalive interval(0 is disabled)."
                },
                "preshared_key": {
                  "type": "string",
                  "description": "Pre-shared key."
                }
              }
            }
          },
          "required": false
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code,-1:Parameter error,-2:File does not exist,-3:uci Initialization error."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "s2s",
                  "set_config",
                  {
                    "lan_ip": "192.168.9.1",
                    "interface": {
                      "mtu": "1560",
                      "listen_port": "51820",
                      "address": [
                        "10.0.0.1",
                        "0:0:0:0:0:ffff:a00:1"
                      ]
                    },
                    "peer": [
                      {
                        "public_key": "4Mss1+aEQMh4z8Ykgs/pwazmgjhWEzil9QreL2HZoEc=",
                        "allowed_ips": [
                          "192.168.8.0/24",
                          "192.168.9.0/24"
                        ]
                      },
                      {
                        "public_key": "6I13DX9LcF5ON15vYOfceSk3PzS2JjLyG0BbkspzDXc=",
                        "allowed_ips": [
                          "192.168.10.0/24",
                          "0:0:0:0:0:ffff:c0a8:a00"
                        ]
                      }
                    ]
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
