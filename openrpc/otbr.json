{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — otbr module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "otbr.generate_thread_network",
      "summary": "Initialize a network with random values, include PAN ID, Extended PAN ID and Network Key.",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "generate_thread_network_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": "0",
                "method": "call",
                "params": [
                  "",
                  "otbr",
                  "generate_thread_network",
                  {}
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "err_code": 0
            }
          }
        }
      ]
    },
