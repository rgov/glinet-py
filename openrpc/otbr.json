          "type": "object",
          "properties": {
            "filename": {
              "type": "string",
              "description": "The name of the exported file"
            },
            "path": {
              "type": "string",
              "description": "The path of the exported file"
            },
            "err_code": {
              "type": "number",
              "description": "Error code."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
