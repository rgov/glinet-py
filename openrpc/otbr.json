    {
      "name": "otbr.get_status",
      "summary": "Get the Thread network status",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "OpenThreadVersionAPI": {
              "type": "string",
              "description": "OpenThread API version"
            },
            "OTBRVersion": {
              "type": "string",
              "description": "ot-br-posix version"
            },
            "ThreadVersion": {
              "type": "string",
              "description": "Thread Specification version, v1.1 , v1.2, v1.3"
            },
            "Network": {
              "type": "object",
              "description": "Thread network information",
              "properties": {
                "Channel": {
                  "type": "number",
                  "description": "Thread network channel. The value ranges from 11 to 26"
                },
                "ExtPanId": {
                  "type": "string",
                  "description": "Thread network Extended PAN ID. Its length is limited to 16 bytes of UTF-8 encoded characters"
                },
                "NetworkKey": {
                  "type": "string",
                  "description": "Thread network key, which is 32 bytes long UTF-8 encoded characters"
                },
                "NetworkName": {
                  "type": "string",
                  "description": "Thread network name. Its length is limited to 1 to 16 characters"
                },
                "PanId": {
                  "type": "number",
                  "description": "Thread network PAN ID, value range: 0<= PAN ID <65535 or 0x0<= PAN ID<0xFFFF"
                },
                "PSKc": {
                  "type": "string",
                  "description": "Thread network PSKc, PSKc is algorithmically generated by Passphrase, ExtendedPanId, and NetworkName,"
                },
                "Passphrase": {
                  "type": "string",
                  "description": "Thread network Passphrase, a user-defined character string that serves as Commissioner Credential and"
                },
                "OnMeshPrefix": {
                  "type": "array",
                  "description": "On-Mesh Prefix"
                },
                "LeaderData": {
                  "type": "object",
                  "description": "Leader data",
                  "properties": {
                    "PartitionId": {
                      "type": "number",
                      "description": "Partition ID of the leader node"
                    },
                    "Weighting": {
                      "type": "number",
                      "description": "Weighting of the leader node"
                    },
                    "DataVersion": {
                      "type": "number",
                      "description": "Data Version of the leader node"
                    },
                    "StableDataVersion": {
                      "type": "number",
                      "description": "Stable Data Version of the leader node"
                    },
                    "LeaderRouterId": {
                      "type": "number",
                      "description": "Leader Router ID of the leader node"
                    }
                  }
                },
                "IPv6": {
                  "type": "array",
                  "description": "IPv6 information"
                },
                "IPv6[x]": {
                  "type": "string",
                  "description": "IPv6[x] information"
                },
                "ActiveDataset": {
                  "type": "string",
                  "description": "Operational Dataset TLVs."
                }
              }
            },
            "RCP": {
              "type": "object",
              "description": "RCP information",
              "properties": {
                "State": {
                  "type": "number",
                  "description": "The state of RCP module, disabled=0, detached=1, child=2, router=3 or leader=4"
                },
                "RCPVersion": {
                  "type": "string",
                  "description": "RCP version"
                },
                "ExtAddress": {
                  "type": "string",
                  "description": "IEEE 802.15.4 Extended Address"
                },
                "EUI64": {
                  "type": "string",
                  "description": "The factory-assigned IEEE EUI-64"
                },
                "TXPower": {
                  "type": "number",
                  "description": "The transmit power in dBm"
                },
                "Rloc16": {
                  "type": "number",
                  "description": "Thread RLOC16 value"
                }
              }
            },
            "err_code": {
              "type": "number",
              "description": "Error code."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": []
    },
