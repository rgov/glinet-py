          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code"
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "remove_crash_log_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "logread",
                  "remove_crash_log",
                  {}
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
    {
      "name": "logread.set_config",
      "summary": "set logread settings",
      "params": [
        {
          "name": "record_size",
          "schema": {
            "type": "number",
            "description": "Single crash log size [default 8192, minimum 4096, this parameter is an integer multiple of 4096]"
          },
          "required": false
        },
        {
          "name": "enable",
          "schema": {
            "type": "boolean",
            "description": "Enable or disable openwrt local log saving"
          },
          "required": true
        },
        {
          "name": "path",
          "schema": {
            "type": "string",
            "description": "openwrt local log save path [do not pass the default path /usr/share/mylog]"
          },
          "required": false
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code"
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "logread",
                  "set_config",
                  {
                    "record_size": 4096,
                    "enable": true,
                    "path": "/usr/share/mylog"
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
    },
    {
      "name": "logread.get_config",
      "summary": "get logread settings",
      "params": [
        {
          "name": "record_size",
          "schema": {
            "type": "number",
            "description": "Single crash log size [default 8192, minimum 4096, this parameter is an integer multiple of 4096]"
          },
          "required": false
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "enable": {
              "type": "boolean",
              "description": "Enable or disable openwrt local log saving"
            },
            "path": {
              "type": "string",
              "description": "openwrt local log save path"
            },
            "err_code": {
              "type": "number",
              "description": "Error code"
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "logread",
                  "get_config",
                  {}
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "record_size": 8192,
              "path": "/usr/share/mylog",
              "enable": true
            }
          }
        }
      ]
    },
    {
      "name": "logread.get_nginx_log",
      "summary": "get nginx log",
      "params": [
        {
          "name": "type",
          "schema": {
            "type": "string",
            "description": "Set the log type to get [ access; error ]"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "log": {
              "type": "string",
              "description": "Output the nginx log of this log type [return the latest 100 lines of log]"
            },
            "err_code": {
              "type": "number",
              "description": "Error code"
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_nginx_log_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "logread",
                  "get_nginx_log",
                  {
                    "type": "access"
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "log": "192.168.8.3 - - [08\\/Aug\\/2022:07:02:39 +0000] "
            }
          }
        }
      ]
    },
