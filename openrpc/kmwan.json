{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — kmwan module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "kmwan.set_interface",
      "summary": "set interface info",
      "params": [
        {
          "name": "interface",
          "schema": {
            "type": "string",
            "description": "detetction interface name"
          },
          "required": true
        },
        {
          "name": "enable_check",
          "schema": {
            "type": "boolean",
            "description": "enable detection"
          },
          "required": true
        },
        {
          "name": "track_mode",
          "schema": {
            "type": "number",
            "description": "Internet status check mode,which takes effect when enbale_check is true[0:passive; 1:force]",
            "oneOf": [
              {
                "const": 0,
                "title": "passive"
              },
              {
                "const": 1,
                "title": "force"
              }
            ]
          },
          "required": true
        },
        {
          "name": "track_proto",
          "schema": {
            "type": "number",
            "description": "detection protocol [0:ipv4 only; 1:ipv6 only; 2:both ipv4 & ipv6]",
            "oneOf": [
              {
                "const": 0,
                "title": "ipv4 only"
              },
              {
                "const": 1,
                "title": "ipv6 only"
              },
              {
                "const": 2,
                "title": "both ipv4 & ipv6"
              }
            ]
          },
          "required": true
        },
        {
          "name": "track_method",
          "schema": {
            "type": "number",
            "description": "detection way [0:ping; 1:httping]",
            "oneOf": [
              {
                "const": 0,
                "title": "ping"
              },
              {
                "const": 1,
                "title": "httping"
              }
            ]
          },
          "required": true
        },
        {
          "name": "enable_ssl",
          "schema": {
            "type": "boolean",
            "description": "Whether ssl is enabled in httping mode"
          },
          "required": false
        },
        {
          "name": "track_ipv4",
          "schema": {
            "type": "array",
            "description": "IPv4 address detected"
          },
          "required": true
        },
        {
          "name": "track_ipv6",
          "schema": {
            "type": "array",
            "description": "IPv6 address detected"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "error code"
            },
            "err_msg": {
              "type": "string",
              "description": "error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_interface_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "kmwan",
                  "set_interface",
                  {
                    "interface": "wan",
                    "enable_check": true,
                    "track_mode": 1,
                    "track_proto": 0,
                    "track_method": 2,
                    "ipv4": [
                      "8.8.4.4",
                      "8.8.8.8",
                      "208.67.222.222",
                      "208.67.220.220"
                    ],
                    "ipv6": [
                      "2001:4860:4860::8844",
                      "2001:4860:4860::8888",
                      "2620:0:ccd::2",
                      "2620:0:ccc::2"
                    ]
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
    },
    {
      "name": "kmwan.set_sensitivity",
      "summary": "set sensitivity",
      "params": [
        {
          "name": "sensitivity",
          "schema": {
            "type": "number",
            "description": "Set detection time interval(unit:s)"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "error code"
            },
            "err_msg": {
              "type": "string",
              "description": "error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_sensitivity_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "kmwan",
                  "set_sensitivity",
                  {
                    "sensitivity": 5
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
    },
    {
      "name": "kmwan.set_config",
      "summary": "set kmwan Settings",
      "params": [
        {
          "name": "mode",
          "schema": {
            "type": "string",
            "description": "mode setting[0:failover; 1:load balance]"
          },
          "required": true
        },
        {
          "name": "interfaces",
          "schema": {
            "type": "array",
            "description": "interface setting",
            "items": {
              "type": "object",
              "properties": {
                "interface": {
                  "type": "string",
                  "description": "interface name"
                },
                "metric": {
                  "type": "number",
                  "description": "link metric [for load balance mode]"
                },
                "weight": {
                  "type": "number",
                  "description": "load weight [for load balance mode, ranges: 0-10]"
                }
              }
            }
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "error code"
            },
            "err_msg": {
              "type": "string",
              "description": "error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "kmwan",
                  "set_config",
                  {
                    "mode": 1,
                    "interfaces": [
                      {
                        "interfacd": "wan",
                        "metric": 10
                      },
                      {
                        "interface": "wwan",
                        "metric": 20
                      }
                    ]
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": null
          }
        }
      ]
    },
    {
