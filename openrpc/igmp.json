{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — igmp module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "igmp.get_config",
      "summary": "get igmp configuration information",
      "params": [],
      "result": {
        "name": "result",
        "schema": {
          "type": "object",
          "properties": {
            "enable": {
              "type": "boolean",
              "description": "Whether to enable igmp."
            },
            "version": {
              "type": "number",
              "description": "igmp version [1,2,3]."
            }
          }
        }
      },
      "examples": [
        {
          "name": "get_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "igmp",
                  "get_config",
                  {}
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {
              "enable": false,
              "version": 3
            }
          }
        }
      ]
    },
    {
      "name": "igmp.set_config",
      "summary": "设置igmp",
      "params": [
        {
          "name": "enable",
          "schema": {
            "type": "boolean",
            "description": "Whether to enable igmp."
          },
          "required": true
        },
        {
          "name": "version",
          "schema": {
            "type": "number",
            "description": "igmp version [1,2,3]."
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code,-1:Parameter error."
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "set_config_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "method": "call",
                "params": [
                  "",
                  "igmp",
                  "set_config",
                  {
                    "version": 3,
                    "enable": false
                  }
                ],
                "id": 1
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    }
  ]
}