{
  "openrpc": "1.3.2",
  "info": {
    "title": "GL.iNet Router 4.x API — cloud-batch-manage module",
    "version": "4.0.0-snapshot",
    "description": "JSON-RPC 2.0 API exposed at POST /rpc on GL.iNet routers. All methods use JSON-RPC method `call` with params = [sid, module, function, args?]. Auth is a separate challenge/login flow yielding `sid`."
  },
  "servers": [
    {
      "name": "router",
      "url": "http://192.168.8.1/rpc"
    }
  ],
  "methods": [
    {
      "name": "cloud-batch-manage.bind_info",
      "summary": "set cloud bind info",
      "params": [
        {
          "name": "username",
          "schema": {
            "type": "string",
            "description": "cloud user name"
          },
          "required": true
        },
        {
          "name": "email",
          "schema": {
            "type": "string",
            "description": "cloud user email"
          },
          "required": true
        },
        {
          "name": "bindtime",
          "schema": {
            "type": "string",
            "description": "router device in cloud bind time"
          },
          "required": true
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "err_code": {
              "type": "number",
              "description": "Error code, -1:argument err"
            },
            "err_msg": {
              "type": "string",
              "description": "Error message"
            }
          }
        }
      },
      "examples": [
        {
          "name": "bind_info_example",
          "params": [
            {
              "name": "request",
              "value": {
                "jsonrpc": "2.0",
                "id": 1,
                "method": "call",
                "params": [
                  "",
                  "cloud-batch-manage",
                  "bind_info",
                  {
                    "username": "glcloud",
                    "email": "126@qq.com",
                    "bindtime": "192168"
                  }
                ]
              }
            }
          ],
          "result": {
            "name": "response",
            "value": {}
          }
        }
      ]
    },
