{
  "name": "modem.set_slot_config",
  "summary": "Set dual SIM card settings. The API only supports setting the built-in cellular modem",
  "request": {
    "jsonrpc": "2.0",
    "method": "call",
    "params": [
      "",
      "modem",
      "set_slot_config",
      {
        "bus": "0001:01:00.0",
        "enable_switch": true,
        "current_sim": "1",
        "main_sim": "1",
        "failover_interval": "120",
        "sim1_profile": "f9FQ3vUzMJmih4Ck",
        "sim2_profile": "o2bCZMB53KHk6HAX",
        "enable_timing": true,
        "hour": "05",
        "min": "00"
      }
    ],
    "id": 1
  },
  "response": {
    "jsonrpc": "2.0",
    "id": 1,
    "result": {}
  }
}