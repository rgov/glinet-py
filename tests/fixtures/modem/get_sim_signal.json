{
  "name": "modem.get_sim_signal",
  "summary": "Get SIM card information, simplified version of get_sim_info interface, does not judge sim card plugged status and registration status",
  "request": {
    "jsonrpc": "2.0",
    "method": "call",
    "params": [
      "",
      "modem",
      "get_sim_signal",
      {}
    ],
    "id": 1
  },
  "response": {
    "jsonrpc": "2.0",
    "id": 1,
    "result": {
      "signal": {
        "mode": 4,
        "strength": 4,
        "rssi": -67,
        "rsrp": -60,
        "rsrq": -10,
        "sinr": 13
      }
    }
  }
}