        "route_flag": 4,
        "rule_id": 6512,
        "dest": "192.168.9.13/32",
        "gateway": "10.8.3.1",
        "metric": 20,
        "mtu": 1500
      }
    ],
    "id": 1
  },
  "response": {
    "jsonrpc": "2.0",
    "id": 1,
    "result": {}
  }
