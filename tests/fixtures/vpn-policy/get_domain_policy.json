{
  "name": "vpn-policy.get_domain_policy",
  "summary": "get domain policy",
  "request": {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "call",
    "params": [
      "",
      "vpn-policy",
      "get_domain_policy",
      {}
    ]
  },
  "response": {
